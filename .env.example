# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PIN shown to the user on first open (4-8 digits). Leave blank to disable PIN gate.
APP_PIN=

# Dhan trading API
DHAN_CLIENTID=
DHAN_ACCESSTOKEN=
DHAN_APIKEY=
DHAN_APISECRET=

# Telegram API (from https://my.telegram.org)
TELEGRAM_API_APP=
TELEGRAM_API_HASH=
