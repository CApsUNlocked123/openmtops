# ── Flask ─────────────────────────────────────────────────────────────────────
# Auto-generated by setup wizard if not set. Set manually for reproducible sessions.
SECRET_KEY=

# Optional PIN to protect the app (4-8 digits). Leave blank to disable.
APP_PIN=

# Set to 1 to run with dummy data (no broker credentials needed).
TESTING=0

# ── Dhan Broker API ───────────────────────────────────────────────────────────
# Get your Client ID and Access Token from: https://dhanhq.co → Partner Account
DHAN_CLIENTID=
DHAN_ACCESSTOKEN=
DHAN_APIKEY=
DHAN_APISECRET=

# ── Telegram API ──────────────────────────────────────────────────────────────
# Get API_APP and API_HASH from: https://my.telegram.org/apps
TELEGRAM_API_APP=
TELEGRAM_API_HASH=

# Numeric ID of the Telegram channel/group to monitor for trading tips.
# Use a tool like @userinfobot in Telegram to find a channel ID.
TELEGRAM_CHANNEL_ID=

# Optional: override the Telethon session file path.
# Useful for Docker (mount a named volume at this path).
# TELETHON_SESSION=/path/to/session/anon
